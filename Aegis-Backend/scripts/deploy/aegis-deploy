#!/usr/bin/env bash
# One-command deploy for aegis-backend. Usage: aegis-deploy [commit-ish, default origin/main]
set -euo pipefail
REPO=/opt/aegis/aegis
BACKEND=$REPO/Aegis-Backend
TARGET=${1:-origin/main}

echo "==> Fetching..."
sudo -u aegis git -C "$REPO" fetch origin

BEFORE=$(sudo -u aegis git -C "$REPO" rev-parse HEAD)
echo "==> Updating $BEFORE -> $TARGET"
if [ "$TARGET" = "origin/main" ]; then
  sudo -u aegis git -C "$REPO" checkout -q main
  sudo -u aegis git -C "$REPO" merge --ff-only origin/main
else
  sudo -u aegis git -C "$REPO" checkout -q "$TARGET"
fi
AFTER=$(sudo -u aegis git -C "$REPO" rev-parse HEAD)

if sudo -u aegis git -C "$REPO" diff --name-only "$BEFORE" "$AFTER" -- Aegis-Backend/package-lock.json | grep -q .; then
  echo "==> Dependencies changed, npm ci..."
  sudo -u aegis bash -c "cd $BACKEND && npm ci"
fi

echo "==> Running migrations..."
sudo -u aegis bash -c "cd $BACKEND && npm run migrate"

echo "==> Restarting service..."
systemctl restart aegis-backend
sleep 2
systemctl is-active aegis-backend
curl -sf http://localhost:3000/health && echo
echo "==> Deployed $(sudo -u aegis git -C "$REPO" log --oneline -1)"
