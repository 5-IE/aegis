PORT=3000
LOG_LEVEL=info
# Number of trusted proxy hops for req.ip (default 1 for single-instance behind one LB)
# TRUST_PROXY_HOPS=1

# Optional: also write all logs (newline-delimited JSON) to this file, in
# addition to stdout/journal. Leave unset to log only to stdout.
# LOG_FILE=/var/log/aegis/app.log

# Optional: Sentry error monitoring. Leave SENTRY_DSN unset to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

DB_HOST=localhost
DB_PORT=3306
DB_USER=aegis
DB_PASSWORD=changeme
DB_NAME=AEGIS

JWT_SECRET=replace-with-at-least-32-random-bytes-base64

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@aegis.local
